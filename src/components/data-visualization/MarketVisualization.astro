---
// Market visualization component
// Displays market data using Chart component
// Props:
//   data: array of market data points (required)
//   symbol: string (default: 'SPY')
//   class: string (additional classes)
//   ...rest: spread to container div
import Chart from '@/components/data-visualization/Chart.astro';

const { data = [], symbol = 'SPY', class: className = '', ...rest } = Astro.props;

// Validate data format
const isValidData = Array.isArray(data) && data.length > 0 &&
  data.every(item =>
    item.timestamp !== undefined &&
    item.close !== undefined &&
    typeof item.close === 'number'
  );

// Extract closing prices and dates for chart
const closingPrices = isValidData ? data.map(d => d.close) : [];
const dates = isValidData ? data.map(d => new Date(d.timestamp).toLocaleDateString()) : [];
---
<div class={`relative w-full h-[360px] bg-canvas-soft rounded-xl overflow-hidden shadow-inset-level-4 ${className}`} {...rest}>
  {data.length === 0 && (
    <div class="absolute inset-0 flex items-center justify-center text-body text-muted">
      <span class="text-2xl">📭</span>
      <span class="ml-2">No market data available for {symbol}</span>
    </div>
  )}

  {data.length > 0 && (
    <Chart
      type="line"
      data={closingPrices}
      labels={dates}
      height="100%"
      width="100%"
      class="absolute inset-0"
    />
  )}

  {/* Gradient overlay for visual appeal */}
  <div class="absolute inset-0 bg-gradient-to-br from-bullish/5 via-neutral/5 to-bearish/5"></div>

  {/* Current price badge */}
  {data.length > 0 && (
    <div class="absolute bottom-4 left-4 bg-white/90 backdrop-blur-sm rounded-lg px-3 py-1 flex items-center gap-2 shadow-sm border border-canvas/30">
      <span class="text-2xl">📊</span>
      <div class="space-y-1">
        <p class="text-xs text-muted font-medium">{symbol}</p>
        <p class="text-lg font-bold text-ink">${{data[data.length - 1].close.toFixed(2)}}</p>
      </div>
    </div>
  )}
</div>