---
// Card component
// Variants: default, outline, elevated, marketing, template
// Props:
//   variant: 'default' | 'outline' | 'elevated' | 'marketing' | 'template' (default: 'default')
//   class: string (additional classes)
//   children: slot
//   ...rest: spread to div element
---
const { variant = 'default', class: className = '', ...rest } = Astro.props;

// Base classes
const base = 'rounded overflow-hidden transition-shadow duration-200';

// Variant classes
const variants = {
  default: 'bg-canvas border border-canvas/30',
  outline: 'bg-transparent border border-canvas/50',
  elevated: 'bg-canvas border-none shadow-sm hover:shadow-md',
  marketing: 'bg-gradient-to-br from-canvas-soft to-white border border-canvas/30',
  template: 'bg-white border border-canvas/20',
};

// Combine classes
const classes = [
  base,
  variants[variant],
  className,
].filter(Boolean).join(' ');
</style>

<div class={classes} {...rest}>
  <slot />
</div>