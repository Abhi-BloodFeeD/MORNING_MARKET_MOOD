---
// Form label component
// Props:
//   htmlFor: string (optional)
//   class: string (additional classes)
//   children: slot
---
const { htmlFor, class: className = '', ...rest } = Astro.props;

// Base classes
const base = 'block text-sm font-medium text-ink mb-2';

// Combine classes
const classes = [base, className].filter(Boolean).join(' ');
</style>

<label for={htmlFor} class={classes} {...rest}>
  <slot />
</label>