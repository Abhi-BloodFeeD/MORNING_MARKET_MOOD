---
// Footer component for Market Bias Predict
---
<footer class="bg-canvas-soft border-t border-hairline">
  <div class="mx-auto flex flex-col sm:flex-row sm:justify-between px-6 py-10 lg:px-8">
    <!-- Company Column -->
    <div class="space-y-4 sm:space-y-0 sm:w-1/3">
      <h3 class="text-ink font-semibold text-lg mb-2">Market Bias Predict</h3>
      <p class="text-body text-muted">
        Premium financial intelligence platform delivering daily market bias analysis.
      </p>
    </div>

    <!-- Links Columns -->
    <div class="flex flex-col sm:flex-row sm:space-x-12 sm:w-2/3 space-y-4 sm:space-y-0">
      <!-- Product -->
      <div class="space-y-2">
        <h4 class="text-xs font-semibold text-ink tracking-wider uppercase">Product</h2>
        <nav class="space-y-1">
          <a href="/dashboard" class="text-sm text-body hover:text-bullish transition-colors">Dashboard</a>
          <a href="/economic-events" class="text-sm text-body hover:text-bullish transition-colors">Economic Events</a>
          <a href="/corporate-news" class="text-sm text-body hover:text-bullish transition-colors">Corporate News</a>
          <a href="/sectors" class="text-sm text-body hover:text-bullish transition-colors">Sectors</a>
          <a href="/global-map" class="text-sm text-body hover:text-bullish transition-colors">Global Map</a>
          <a href="/history" class="text-sm text-body hover:text-bullish transition-colors">History</a>
        </nav>
      </div>

      <!-- Company -->
      <div class="space-y-2">
        <h4 class="text-xs font-semibold text-ink tracking-wider uppercase">Company</h4>
        <nav class="space-y-1">
          <a href="/about" class="text-sm text-body hover:text-bullish transition-colors">About</a>
          <a href="/contact" class="text-sm text-body hover:text-bullish transition-colors">Contact</a>
          <a href="/blog" class="text-sm text-body hover:text-bullish transition-colors">Blog</a>
        </nav>
      </div>

      <!-- Legal -->
      <div class="space-y-2">
        <h4 class="text-xs font-semibold text-ink tracking-wider uppercase">Legal</h4>
        <nav class="space-y-1">
          <a href="/privacy" class="text-sm text-body hover:text-bullish transition-colors">Privacy</a>
          <a href="/terms" class="text-sm text-body hover:text-bullish transition-colors">Terms</a>
        </nav>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-hairline mt-10">
    <div class="mx-auto flex flex-col sm:flex-row sm:justify-between px-6 py-6 lg:px-8 text-xs text-muted">
      <span>&copy; {new Date().getFullYear()} Market Bias Predict. All rights reserved.</span>
      <div class="flex space-x-4 sm:mt-0 mt-2">
        <a href="#" class="hover:text-bullish transition-colors">Twitter</a>
        <a href="#" class="hover:text-bullish transition-colors">LinkedIn</a>
        <a href="#" class="hover:text-bullish transition-colors">GitHub</a>
      </div>
    </div>
  </div>
</footer>