---
// Header component for Market Bias Predict
// Contains logo, navigation, and CTAs
---
<header class="bg-canvas-soft shadow-inset-hairline">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center space-x-3">
      <!-- TODO: Replace with actual logo -->
      <span class="text-ink font-semibold text-xl">Market Bias Predict</span>
    </a>

    <!-- Navigation (Desktop) -->
    <nav class="hidden md:flex space-x-8">
      <a href="/dashboard" class="text-body hover:text-bullish transition-colors">Dashboard</a>
      <a href="/economic-events" class="text-body hover:text-bullish transition-colors">Economic Events</a>
      <a href="/corporate-news" class="text-body hover:text-bullish transition-colors">Corporate News</a>
      <a href="/sectors" class="text-body hover:text-bullish transition-colors">Sectors</a>
      <a href="/global-map" class="text-body hover:text-bullish transition-colors">Global Map</a>
      <a href="/history" class="text-body hover:text-bullish transition-colors">History</a>
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden md:flex items-center space-x-4">
      <button class="btn-secondary-sm">Log In</button>
      <button class="btn-primary-sm">Sign Up</button>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-button" class="md:hidden p-2" aria-label="Open main menu">
      <!-- Hamburger icon (simple) -->
      <svg class="h-5 w-5 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu (hidden by default) -->
  <div id="mobile-menu" class="md:hidden hidden bg-canvas-soft border-t border-hairline">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href="/dashboard" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">Dashboard</a>
      <a href="/economic-events" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">Economic Events</a>
      <a href="/corporate-news" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">Corporate News</a>
      <a href="/sectors" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">Sectors</a>
      <a href="/global-map" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">Global Map</a>
      <a href="/history" class="block px-3 py-2 rounded-md text-base font-medium text-body hover:bg-canvas-soft-2 hover:text-bullish">History</a>
    </div>
    <div class="border-t border-hairline pt-4 pb-5">
      <div class="px-4">
        <button class="w-full btn-secondary-sm mb-2">Log In</button>
        <button class="w-full btn-primary-sm">Sign Up</button>
      </div>
    </div>
  </div>
</header>

<style>
  /* Mobile menu toggle logic would be handled by Alpine.js or similar in a real implementation */
  /* For now, we'll keep it static; interactivity can be added later */
</style>