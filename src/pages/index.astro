---
// Landing Page for Market Bias Predict
import MarketVisualization from '@/components/data-visualization/MarketVisualization.astro';

// Fetch real market data for the hero visualization
const marketDataResponse = await fetch(new URL('/api/market-data?symbol=SPY&timeframe=1d&limit=30', import.meta.env.SITE ?? 'http://localhost:4321'));
const marketData = marketDataResponse.ok ? await marketDataResponse.json() : { data: [] };
<main class="min-h-screen flex flex-col">
  <!-- Hero Section -->
  <section class="relative flex-0 pt-20 pb-24 bg-canvas">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
        <!-- Hero Text -->
        <div class="lg:w-1/2 space-y-6">
          <h1 class="text-display-xl text-ink">
            Understand Today's Market in 30 Seconds
          </h1>
          <p class="text-body-lg text-body">
            AI-powered analysis of global economic and corporate events.
          </p>
          <div class="flex space-x-4">
            <Button variant="primary" size="lg">
              View Today's Bias
            </Button>
            <Button variant="secondary" size="lg">
              See Historical Accuracy
            </Button>
          </div>
        </div>

        <!-- Hero Visual (Actual Market Data) -->

        <div class="lg:w-1/2 flex lg:justify-end mt-12 lg:mt-0">
          <MarketVisualization
            data={marketData.data || []}
            symbol="SPY"
            class="w-[480px] h-[360px]"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Features / How it works -->
  <section class="pt-16 pb-24 bg-canvas">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 class="text-display-lg text-ink text-center mb-12">
        How Market Bias Predict Works
      </h2>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 text-center">
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center bg-bullish/10 rounded-lg text-bullish">
            <span class="text-2xl">📰</span>
          </div>
          <h3 class="text-font-medium text-ink">News Collection</h3>
          <p class="text-body text-muted">
            We gather the most important economic and corporate events from global sources.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center bg-bullish/10 rounded-lg text-bullish">
            <span class="text-2xl">🔗</span>
          </div>
          <h3 class="text-font-medium text-ink">Event Correlation</h3>
          <p class="text-body text-muted">
            Our AI analyzes how events connect and influence each other.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center bg-bullish/10 rounded-lg text-bullish">
            <span class="text-2xl">📊</span>
          </div>
          <h3 class="text-font-medium text-ink">Bias Calculation</h3>
          <p class="text-body text-muted">
            We calculate market bias based on impact, sentiment, and sector exposure.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex h-12 w-12 items-center justify-center bg-bullish/10 rounded-lg text-bullish">
            <span class="text-2xl">🎯</span>
          </div>
          <h3 class="text-font-medium text-ink">Actionable Insight</h3>
          <p class="text-body text-muted">
            Get a clear bullish/bearish/neutral bias with confidence score.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action Band -->
  <section class="pt-20 pb-24 bg-canvas-soft">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col items-center text-center space-y-8">
        <h2 class="text-display-lg text-ink">
          Join thousands of investors who trust our analysis
        </h2>
        <p class="text-body-lg text-body">
          Start your free trial and get today's market bias delivered to your inbox.
        </p>
        <div class="flex space-x-4">
          <Button variant="primary" size="lg">
            Get Started Free
          </Button>
          <Button variant="secondary" size="lg">
            Learn More
          </Button>
        </div>
      </div>
    </div>
  </section>
</main>

<style>
  /* Keyframe animation for gradient placeholder */
  @keyframes gradient_shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .animate-gradient_shift {
    animation: gradient_shift 8s ease infinite;
  }
</style>