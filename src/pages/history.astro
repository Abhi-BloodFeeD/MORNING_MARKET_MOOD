// Historical data page
import MarketVisualization from '@/components/data-visualization/MarketVisualization.astro';
import MetricCard from '@/components/data-visualization/MetricCard.astro';

// Fetch historical data for multiple timeframes
async function fetchHistoricalData(symbol, timeframe, limit) {
  try {
    const response = await fetch(new URL(`/api/market-data?symbol=${encodeURIComponent(symbol)}&timeframe=${timeframe}&limit=${limit}`, import.meta.env.SITE ?? 'http://localhost:4321'));
    if (!response.ok) throw new Error(`Failed to fetch ${timeframe} data`);
    const data = await response.json();
    return data.data || [];
  } catch (error) {
    console.error(`Error fetching ${timeframe} data:`, error);
    return [];
  }
}

// Fetch data for different periods
const [spy1d, spy1w, spy1m, spy3m] = await Promise.all([
  fetchHistoricalData('SPY', '1d', 30),   // 30 days
  fetchHistoricalData('SPY', '1w', 12),   // 12 weeks
  fetchHistoricalData('SPY', '1m', 6),    // 6 months
  fetchHistoricalData('SPY', '1m', 12)    // 12 months
]);

// Calculate performance metrics
function calculatePerformance(data) {
  if (data.length < 2) return { totalReturn: 0, volatility: 0, sharpe: 0 };

  const returns = data.slice(1).map((d, i) => (d.close - data[i].close) / data[i].close);
  const totalReturn = (data[data.length - 1].close - data[0].close) / data[0].close;
  const avgReturn = returns.reduce((sum, r) => sum + r, 0) / returns.length;
  const volatility = Math.sqrt(returns.reduce((sum, r) => sum + Math.pow(r - avgReturn, 2), 0) / returns.length) * Math.sqrt(252); // Annualized
  const sharpe = (avgReturn * 252) / (volatility || 0.001); // Simplified Sharpe ratio

  return {
    totalReturn: totalReturn * 100, // as percentage
    volatility: volatility * 100,   // as percentage
    sharpe: sharpe.toFixed(2)
  };
}

const perf1d = calculatePerformance(spy1d);
const perf1w = calculatePerformance(spy1w);
const perf1m = calculatePerformance(spy1m);
const perf3m = calculatePerformance(spy3m);

<div>
  <h1>{displayName}</h1>
  <p>This is the {displayName} page.</p>
</div>